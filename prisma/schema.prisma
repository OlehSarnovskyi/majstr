generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?
  googleId  String?  @unique @map("google_id")
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  phone        String?
  avatar       String?
  bio          String?
  city         String?
  workingHours Json?   @map("working_hours")
  timezone     String  @default("Europe/Bratislava")
  role      Role     @default(CLIENT)
  roleChosen               Boolean   @default(false) @map("role_chosen")
  emailVerified            Boolean   @default(false) @map("email_verified")
  emailVerificationToken   String?   @map("email_verification_token")
  resetToken               String?   @map("reset_token")
  resetTokenExpiry         DateTime? @map("reset_token_expiry")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bookingsAsClient Booking[] @relation("ClientBookings")
  bookingsAsMaster Booking[] @relation("MasterBookings")
  services         Service[]
  masterProfile    MasterProfile?

  @@map("users")
}

model MasterProfile {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  slug        String   @unique
  description String?
  isVerified  Boolean  @default(false) @map("is_verified")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("master_profiles")
}

model ServiceCategory {
  id       String    @id @default(uuid())
  name     String    @unique
  slug     String    @unique
  icon     String?
  services Service[]

  @@map("service_categories")
}

model Service {
  id              String          @id @default(uuid())
  name            String
  description     String
  price           Decimal         @db.Decimal(10, 2)
  durationMinutes Int             @map("duration_minutes")
  categoryId      String          @map("category_id")
  masterId        String          @map("master_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  category ServiceCategory @relation(fields: [categoryId], references: [id])
  master   User            @relation(fields: [masterId], references: [id])
  bookings Booking[]

  @@map("services")
}

model Booking {
  id        String        @id @default(uuid())
  clientId  String        @map("client_id")
  masterId  String        @map("master_id")
  serviceId String        @map("service_id")
  startTime DateTime      @map("start_time")
  endTime   DateTime      @map("end_time")
  status         BookingStatus @default(PENDING)
  note           String?
  address        String?
  estimatedPrice Decimal?      @db.Decimal(10, 2) @map("estimated_price")
  actualPrice    Decimal?      @db.Decimal(10, 2) @map("actual_price")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  client  User    @relation("ClientBookings", fields: [clientId], references: [id])
  master  User    @relation("MasterBookings", fields: [masterId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])

  @@map("bookings")
}

enum Role {
  CLIENT
  MASTER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
