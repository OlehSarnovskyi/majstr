# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/majster"

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Public URL of the app (used for OAuth redirects and email links)
FRONTEND_URL="https://majstr.app"
# Comma-separated list of allowed CORS origins (overrides FRONTEND_URL if set)
# CORS_ORIGINS="https://majstr.app,https://majster-sk.vercel.app"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="change-me-to-a-long-random-secret"

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
# Get credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="https://majstr.app/api/auth/google/callback"

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Leave empty in dev — emails are printed to the console instead
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@majstr.app"
SMTP_PASS="your-smtp-password"
SMTP_FROM="Majstr <noreply@majstr.app>"

# ─── Notes ────────────────────────────────────────────────────────────────────
# Avatars are stored in /uploads/avatars inside the container.
# For persistent storage across deploys, mount a volume or migrate to S3/R2.
