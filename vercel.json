{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npx nx build web --configuration=production",
  "outputDirectory": "dist/apps/web/browser",
  "ignoreCommand": "! git diff HEAD^ HEAD --name-only | grep -qE '^apps/web|^vercel\\.json|^package'",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://p01--majster-api--qsdsbvpywc6x.code.run/api/:path*"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://p01--majster-api--qsdsbvpywc6x.code.run/sitemap.xml"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
